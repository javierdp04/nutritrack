---
import NavigationApp from "./components/navigationApp.astro";
import AppStyles from "./components/appStyles.astro";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>Seguimiento de peso — NutriTrack</title>
	</head>
	<body>
		<AppStyles />
		<NavigationApp active="peso" />

		<main class="app">
			<section class="grid cols-2">
				<div class="panel">
					<h1>Registrar peso</h1>
					<p class="muted">Se guardará con la fecha de hoy.</p>

					<form id="pesoForm" novalidate>
						<div class="field">
							<label for="peso">Peso actual (kg)</label>
							<input type="number" id="peso" name="peso" min="30" max="250" step="0.1" required />
							<small class="error" data-error-for="peso"></small>
						</div>
						<div class="actions">
							<button type="submit" class="btn">Registrar</button>
						</div>
						<p id="ok" class="notice" hidden>Peso guardado correctamente.</p>
					</form>
				</div>

				<div class="panel">
					<h2>Resumen</h2>
					<div class="summary">
						<div class="sum-row">
							<span class="sum-label">Último peso</span>
							<span class="sum-val"><span id="ultimo">—</span> kg</span>
						</div>
						<div class="sum-row">
							<span class="sum-label">Cambio vs anterior</span>
							<span class="sum-val" id="deltaPrev">—</span>
						</div>
						<div class="sum-row">
							<span class="sum-label">Cambio total</span>
							<span class="sum-val" id="deltaTotal">—</span>
						</div>
					</div>
				</div>
			</section>

			<section class="panel chart-panel">
				<h2>Evolución</h2>
				<svg id="chart" viewBox="0 0 640 220" class="chart"></svg>
				<p class="muted" id="chartEmpty" hidden>Sin datos suficientes para el gráfico.</p>
			</section>

			<section class="panel">
				<h2>Histórico</h2>
				<table>
					<thead>
						<tr><th>Fecha</th><th>Peso (kg)</th><th>Variación</th></tr>
					</thead>
					<tbody id="tbody">
						<tr><td colspan="3" class="muted">Sin registros todavía.</td></tr>
					</tbody>
				</table>
			</section>
		</main>

		<script>
			import { api, requireAuth } from "../scripts/api";

			requireAuth();

			type Registro = { peso: number; fecha: string };

			const form = document.getElementById("pesoForm") as HTMLFormElement;
			const okMsg = document.getElementById("ok");

			const setError = (field: string, message: string) => {
				const el = document.querySelector(`[data-error-for="${field}"]`);
				if (el) el.textContent = message;
				const input = document.getElementById(field);
				if (input) input.classList.toggle("invalid", Boolean(message));
			};

			function formatDelta(delta: number): string {
				if (delta === 0) return "Sin cambios";
				const signo = delta > 0 ? "+" : "";
				return `${signo}${delta.toFixed(1)} kg`;
			}

			function render(registros: Registro[]) {
				const tbody = document.getElementById("tbody")!;
				if (registros.length === 0) {
					tbody.innerHTML = `<tr><td colspan="3" class="muted">Sin registros todavía.</td></tr>`;
					document.getElementById("ultimo")!.textContent = "—";
					return;
				}

				document.getElementById("ultimo")!.textContent = String(registros[0].peso);
				if (registros.length >= 2) {
					document.getElementById("deltaPrev")!.textContent = formatDelta(+(registros[0].peso - registros[1].peso).toFixed(1));
				}
				const primero = registros[registros.length - 1].peso;
				document.getElementById("deltaTotal")!.textContent = formatDelta(+(registros[0].peso - primero).toFixed(1));

				tbody.innerHTML = registros.map((r, i) => {
					const anterior = registros[i + 1];
					const delta = anterior ? +(r.peso - anterior.peso).toFixed(1) : 0;
					return `<tr>
						<td>${r.fecha}</td>
						<td>${r.peso.toFixed(1)}</td>
						<td>${anterior ? formatDelta(delta) : "—"}</td>
					</tr>`;
				}).join("");

				drawChart(registros);
			}

			function drawChart(registros: Registro[]) {
				const svg = document.getElementById("chart") as SVGSVGElement | null;
				const empty = document.getElementById("chartEmpty");
				if (!svg) return;
				if (registros.length < 2) {
					svg.setAttribute("hidden", "");
					empty?.removeAttribute("hidden");
					return;
				}
				svg.removeAttribute("hidden");
				empty?.setAttribute("hidden", "");

				const series = [...registros].reverse();
				const pesos = series.map(r => r.peso);
				const min = Math.min(...pesos) - 0.5;
				const max = Math.max(...pesos) + 0.5;
				const w = 640, h = 220, pad = 30;
				const stepX = (w - pad * 2) / (series.length - 1);

				const coords = series.map((r, i) => {
					const x = pad + i * stepX;
					const y = pad + (h - pad * 2) * (1 - (r.peso - min) / (max - min || 1));
					return { x, y, r };
				});

				const pathPoints = coords.map(c => `${c.x.toFixed(1)},${c.y.toFixed(1)}`).join(" ");
				const area = `${pad},${h - pad} ${pathPoints} ${w - pad},${h - pad}`;

				svg.innerHTML = `
					<defs>
						<linearGradient id="areaGrad" x1="0" x2="0" y1="0" y2="1">
							<stop offset="0%" stop-color="#52B788" stop-opacity="0.4" />
							<stop offset="100%" stop-color="#52B788" stop-opacity="0" />
						</linearGradient>
					</defs>
					<polygon fill="url(#areaGrad)" points="${area}" />
					<polyline fill="none" stroke="#52B788" stroke-width="2.5" points="${pathPoints}" />
					${coords.map(c => `<circle cx="${c.x}" cy="${c.y}" r="3.5" fill="#fff" />`).join("")}
					<text x="${pad}" y="${h - 8}" fill="rgba(255,255,255,0.5)" font-size="11">${series[0].fecha}</text>
					<text x="${w - pad}" y="${h - 8}" text-anchor="end" fill="rgba(255,255,255,0.5)" font-size="11">${series[series.length - 1].fecha}</text>
				`;
			}

			async function reload() {
				try {
					const registros = await api<Registro[]>("/peso", { auth: true });
					render(registros);
				} catch { /* silencioso */ }
			}

			form?.addEventListener("submit", async (e) => {
				e.preventDefault();
				okMsg?.setAttribute("hidden", "");
				setError("peso", "");
				const peso = Number((document.getElementById("peso") as HTMLInputElement).value);
				if (!(peso >= 30 && peso <= 250)) {
					setError("peso", "Peso entre 30 y 250 kg.");
					return;
				}
				try {
					await api("/peso", { method: "POST", auth: true, body: JSON.stringify({ peso }) });
					(document.getElementById("peso") as HTMLInputElement).value = "";
					okMsg?.removeAttribute("hidden");
					reload();
				} catch (err: any) {
					setError("peso", err?.error ?? "No se pudo guardar.");
				}
			});

			reload();
		</script>

		<style>
			.actions { margin-top: 0.5rem; }
			.summary { display: flex; flex-direction: column; gap: 0.75rem; }
			.sum-row {
				display: flex;
				justify-content: space-between;
				padding: 0.7rem 0;
				border-bottom: 1px solid rgba(255,255,255,0.08);
			}
			.sum-label { color: rgba(255,255,255,0.65); font-size: 0.9rem; }
			.sum-val { font-weight: 700; }
			.chart-panel { margin-top: 1.25rem; }
			.chart { width: 100%; height: auto; }
		</style>
	</body>
</html>
