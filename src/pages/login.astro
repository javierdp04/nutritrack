---
import NavigationStart from "./components/navigationStart.astro"
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Iniciar sesión — NutriTrack</title>
	</head>
	<body>
		<NavigationStart />

		<main>
			<section class="card">
				<header class="cardHeader">
					<h1>Bienvenido de vuelta</h1>
					<p>Inicia sesión para continuar tu progreso</p>
				</header>

				<form id="loginForm" novalidate>
					<div class="field">
						<label for="email">Email</label>
						<input
							type="email"
							id="email"
							name="email"
							autocomplete="email"
							placeholder="tu@correo.com"
							required
						/>
						<small class="error" data-error-for="email"></small>
					</div>

					<div class="field">
						<label for="password">Contraseña</label>
						<input
							type="password"
							id="password"
							name="password"
							autocomplete="current-password"
							placeholder="Tu contraseña"
							required
						/>
						<small class="error" data-error-for="password"></small>
					</div>

					<div class="forgotRow">
						<a href="#" class="forgotLink">¿Olvidaste tu contraseña?</a>
					</div>

					<small class="error formError" data-error-for="form"></small>

					<button type="submit" class="submitButton">Entrar</button>

					<p class="registerLink">
						¿Aún no tienes cuenta? <a href="/register">Regístrate</a>
					</p>
				</form>
			</section>
		</main>

		<script>
			import { api, auth, redirectIfAuthenticated } from "../scripts/api";
			import { EMAIL_REGEX, setError, clearErrors } from "../scripts/formUtils";

			redirectIfAuthenticated();

			const form = document.getElementById("loginForm") as HTMLFormElement;

			form?.addEventListener("submit", async (e) => {
				/*
				e: Evento que se emite
				*/
				e.preventDefault();
				const fd = new FormData(form);
				const data = {
					email: String(fd.get("email") ?? "").trim(),
					password: String(fd.get("password") ?? ""),
				};
				if (!validate(data)) return;

				try {
					const res = await api<{ token: string; rol: string; nombre: string }>("/login", {
						method: "POST",
						body: JSON.stringify(data),
					});
					auth.save(res.token, res.rol, res.nombre);
					window.location.href = res.rol === "admin" ? "/admin/usuarios" : "/dashboard";
				} catch (err: any) {
					setError("form", err?.error ?? "No se pudo iniciar sesión.");
				}
			});

			const validate = (data: Record<string, string>) => {
				let ok = true;
				clearErrors(["email", "password", "form"]);

				if (!EMAIL_REGEX.test(data.email)) {
					setError("email", "Introduce un email válido.");
					ok = false;
				}
				if (data.password.length === 0) {
					setError("password", "Introduce tu contraseña.");
					ok = false;
				}
				return ok;
			};

			
		</script>
	</body>
</html>

<style>
	html, body {
		height: 100%;
		width: 100%;
		margin: 0;
	}
	body {
		min-height: 100%;
		background-image: url("/assets/landingBackGround2.png");
		background-position: center;
		background-size: cover;
		background-repeat: no-repeat;
		font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
	}
	main {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 6rem 1.5rem 3rem;
	}

	.card {
		width: 100%;
		max-width: 420px;
		padding: 2.5rem 2rem;
		background: rgba(255, 255, 255, 0.04);
		backdrop-filter: blur(16px) saturate(160%);
		-webkit-backdrop-filter: blur(16px) saturate(160%);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 20px;
		box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.35);
		color: #fff;
	}

	.cardHeader {
		text-align: center;
		margin-bottom: 1.75rem;
	}
	.cardHeader h1 {
		font-size: 2rem;
		font-weight: 800;
		margin: 0 0 0.5rem;
		background: linear-gradient(135.2deg, #52B788 0.6%, #2D6A4F 98.1%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.cardHeader p {
		color: rgba(255, 255, 255, 0.75);
		margin: 0;
		font-size: 0.95rem;
	}

	form {
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
	}
	.field {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	label {
		font-size: 0.85rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.85);
	}
	input {
		width: 100%;
		box-sizing: border-box;
		padding: 0.8rem 1rem;
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 12px;
		color: #fff;
		font-size: 1rem;
		transition: border-color 0.2s, background 0.2s;
	}
	input::placeholder {
		color: rgba(255, 255, 255, 0.4);
	}
	input:focus {
		outline: none;
		border-color: #52B788;
		background: rgba(255, 255, 255, 0.09);
	}
	input.invalid {
		border-color: #e05757;
	}

	.error {
		min-height: 1rem;
		font-size: 0.8rem;
		color: #ff8a8a;
	}
	.formError {
		text-align: center;
	}

	.forgotRow {
		display: flex;
		justify-content: flex-end;
		margin-top: -0.3rem;
	}
	.forgotLink {
		font-size: 0.82rem;
		color: rgba(255, 255, 255, 0.65);
		text-decoration: none;
	}
	.forgotLink:hover {
		color: #52B788;
		text-decoration: underline;
	}

	.submitButton {
		margin-top: 0.5rem;
		padding: 0.9rem 1.5rem;
		background: #2D6A4F;
		color: #fff;
		border: none;
		border-radius: 50px;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
		transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1),
			box-shadow 0.2s cubic-bezier(0.4, 0, 0.2, 1),
			background 0.2s;
		box-shadow: 0 4px 15px rgba(45, 106, 79, 0.3);
	}
	.submitButton:hover {
		background: #35805f;
		transform: translateY(-1px);
		box-shadow: 0 6px 20px rgba(45, 106, 79, 0.45);
	}
	.submitButton:active {
		transform: translateY(0);
	}

	.registerLink {
		text-align: center;
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.7);
		margin: 0.5rem 0 0;
	}
	.registerLink a {
		color: #52B788;
		text-decoration: none;
		font-weight: 600;
	}
	.registerLink a:hover {
		text-decoration: underline;
	}
</style>
</content>
</invoke>