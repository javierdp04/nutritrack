---
interface Props {
    active?: string;
}
const { active = "" } = Astro.props;

const links = [
    { href: "/dashboard", label: "Inicio", key: "dashboard" },
    { href: "/datos-fisicos", label: "Datos físicos", key: "datos" },
    { href: "/dieta", label: "Dieta", key: "dieta" },
    { href: "/peso", label: "Peso", key: "peso" },
    { href: "/recetas", label: "Recetas", key: "recetas" },
];
---

<header>
    <nav>
        <a href="/dashboard" class="brand">
            <img class="logo" src="/assets/nutriTrackLogoNB.png" alt="NutriTrack" />
        </a>

        <ul>
            {links.map(l => (
                <li>
                    <a href={l.href} class:list={[{ active: l.key === active }]}>{l.label}</a>
                </li>
            ))}
            <li id="adminNavSlot" hidden>
                <a href="/admin/usuarios" class:list={[{ active: active === "admin" }]}>Admin</a>
            </li>
        </ul>

        <div class="right">
            <span id="userGreeting" class="greeting"></span>
            <button id="logoutBtn" class="logout">Salir</button>
        </div>
    </nav>
</header>

<script>
    import { auth, logout } from "../../scripts/api";

    const greeting = document.getElementById("userGreeting");
    if (greeting && auth.nombre) greeting.textContent = `Hola, ${auth.nombre}`;

    if (auth.rol === "admin") {
        document.getElementById("adminNavSlot")?.removeAttribute("hidden");
    }

    document.getElementById("logoutBtn")?.addEventListener("click", () => logout());
</script>

<style>
    nav {
        top: 0;
        position: fixed;
        height: 60px;
        width: 80%;
        max-width: 1100px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        z-index: 10;
        padding: 10px 20px;
        margin: 1rem;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(12px) saturate(160%);
        -webkit-backdrop-filter: blur(12px) saturate(160%);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
        box-sizing: border-box;
    }
    ul {
        display: flex;
        list-style: none;
        gap: 0.25rem;
        margin: 0;
        padding: 0;
    }
    a {
        padding: 0.6rem 0.9rem;
        text-decoration: none;
        color: rgba(255, 255, 255, 0.75);
        font-size: 0.95rem;
        border-radius: 10px;
        transition: color 0.15s, background 0.15s;
    }
    a:hover, a.active {
        color: #fff;
        background: rgba(255, 255, 255, 0.07);
    }
    img.logo {
        height: 44px;
        width: auto;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
    }
    .right {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .greeting {
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.85rem;
    }
    .logout {
        border: 1px solid rgba(255, 255, 255, 0.15);
        background: transparent;
        color: rgba(255, 255, 255, 0.8);
        padding: 0.5rem 0.9rem;
        border-radius: 50px;
        cursor: pointer;
        font-size: 0.85rem;
        transition: all 0.2s;
    }
    .logout:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
    }

    @media (max-width: 720px) {
        nav { width: calc(100% - 2rem); padding: 10px 12px; }
        .greeting { display: none; }
        ul { gap: 0; }
        a { padding: 0.5rem 0.55rem; font-size: 0.8rem; }
    }
</style>
