---
// Estilos base compartidos por las pantallas privadas.
// Se inyectan al incluir este componente.
---

<style is:global>
    html, body {
        height: 100%;
        width: 100%;
        margin: 0;
    }
    body {
        min-height: 100%;
        background-image: url("/assets/landingBackGround2.png");
        background-position: center;
        background-size: cover;
        background-repeat: no-repeat;
        background-attachment: fixed;
        color: #fff;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    }
    main.app {
        max-width: 1100px;
        margin: 0 auto;
        padding: 6rem 1.5rem 3rem;
    }
    .panel {
        background: rgba(255, 255, 255, 0.04);
        backdrop-filter: blur(16px) saturate(160%);
        -webkit-backdrop-filter: blur(16px) saturate(160%);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 1.75rem;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
    }
    h1, h2, h3 { margin-top: 0; }
    h1 { font-size: 2rem; font-weight: 800; }
    h2 { font-size: 1.3rem; font-weight: 700; }
    .muted { color: rgba(255, 255, 255, 0.65); }
    .accent {
        background: linear-gradient(135.2deg, #52B788 0.6%, #2D6A4F 98.1%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .kcal-highlight {
        background: linear-gradient(135deg, #FFD93D 0%, #FF9F1C 60%, #FF6B35 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 2px 14px rgba(255, 159, 28, 0.55));
        font-weight: 900;
        font-size: 2.8rem;
        letter-spacing: -0.02em;
    }
    .kcal-highlight small {
        -webkit-text-fill-color: rgba(255, 255, 255, 0.7);
        background: none;
        font-size: 0.95rem;
        font-weight: 600;
        margin-left: 0.3rem;
    }
    .btn {
        display: inline-block;
        padding: 0.75rem 1.4rem;
        background: #2D6A4F;
        color: #fff;
        border: none;
        border-radius: 50px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s;
        box-shadow: 0 4px 15px rgba(45, 106, 79, 0.3);
    }
    .btn:hover {
        background: #35805f;
        transform: translateY(-1px);
    }
    .btn.ghost {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.18);
        box-shadow: none;
    }
    .btn.ghost:hover {
        background: rgba(255, 255, 255, 0.06);
    }
    .btn.danger {
        background: #a8322f;
        box-shadow: 0 4px 15px rgba(168, 50, 47, 0.3);
    }
    .btn.danger:hover { background: #c23b38; }

    input, select, textarea {
        width: 100%;
        box-sizing: border-box;
        padding: 0.75rem 0.95rem;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 12px;
        color: #fff;
        font-size: 1rem;
        font-family: inherit;
    }

    option {
        background-color: #2D6A4F;
    }

    input::placeholder, textarea::placeholder { color: rgba(255, 255, 255, 0.4); }
    input:focus, select:focus, textarea:focus {
        outline: none;
        border-color: #52B788;
        background: rgba(255, 255, 255, 0.09);
    }
    input.invalid, select.invalid { border-color: #e05757; }
    label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
        margin-bottom: 0.4rem;
    }
    .field { margin-bottom: 1rem; }
    .error { min-height: 1rem; font-size: 0.8rem; color: #ff8a8a; }
    .notice {
        padding: 0.85rem 1rem;
        border-radius: 12px;
        border: 1px solid rgba(82, 183, 136, 0.35);
        background: rgba(82, 183, 136, 0.1);
        color: #d9f7e8;
        font-size: 0.9rem;
    }
    .notice.warn {
        border-color: rgba(255, 180, 80, 0.35);
        background: rgba(255, 180, 80, 0.08);
        color: #ffe2b3;
    }
    .notice.error {
        border-color: rgba(224, 87, 87, 0.35);
        background: rgba(224, 87, 87, 0.08);
        color: #ffcaca;
    }
    .grid {
        display: grid;
        gap: 1.25rem;
    }
    .cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    @media (max-width: 720px) {
        .cols-2, .cols-3 { grid-template-columns: 1fr; }
    }
    table {
        width: 100%;
        border-collapse: collapse;
    }
    th, td {
        padding: 0.75rem 0.5rem;
        text-align: left;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    th { color: rgba(255, 255, 255, 0.6); font-weight: 600; font-size: 0.85rem; }
</style>
