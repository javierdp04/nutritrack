---
import NavigationStart from "./components/navigationStart.astro"
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Registro — NutriTrack</title>
	</head>
	<body>
		<NavigationStart />

		<main>
			<section class="card">
				<header class="cardHeader">
					<h1>Crea tu cuenta</h1>
					<p>Empieza a seguir tu nutrición en menos de un minuto</p>
				</header>

				<form id="registerForm" novalidate>
					<div class="field">
						<label for="nombre">Nombre</label>
						<input
							type="text"
							id="nombre"
							name="nombre"
							minlength="3"
							maxlength="20"
							autocomplete="name"
							placeholder="Tu nombre"
							required
						/>
						<small class="error" data-error-for="nombre"></small>
					</div>

					<div class="field">
						<label for="email">Email</label>
						<input
							type="email"
							id="email"
							name="email"
							autocomplete="email"
							placeholder="tu@correo.com"
							required
						/>
						<small class="error" data-error-for="email"></small>
					</div>

					<div class="field">
						<label for="password">Contraseña</label>
						<input
							type="password"
							id="password"
							name="password"
							minlength="8"
							autocomplete="new-password"
							placeholder="Mínimo 8 caracteres"
							required
						/>
						<small class="error" data-error-for="password"></small>
					</div>

					<div class="field">
						<label for="passwordConfirm">Repite la contraseña</label>
						<input
							type="password"
							id="passwordConfirm"
							name="passwordConfirm"
							minlength="8"
							autocomplete="new-password"
							placeholder="Repite tu contraseña"
							required
						/>
						<small class="error" data-error-for="passwordConfirm"></small>
					</div>

					<small class="error formError" data-error-for="form"></small>

					<button type="submit" class="submitButton">Crear cuenta</button>

					<p class="loginLink">
						¿Ya tienes cuenta? <a href="/login">Inicia sesión</a>
					</p>
				</form>
			</section>
		</main>

		<script>
			import { api, auth, redirectIfAuthenticated } from "../scripts/api";
			import { EMAIL_REGEX, setError, clearErrors } from "../scripts/formUtils";

			redirectIfAuthenticated();

			const form = document.getElementById("registerForm") as HTMLFormElement;

			form?.addEventListener("submit", async (e) => {
				/*
				e: evento que se emite
				*/
				e.preventDefault();
				const fd = new FormData(form);
				const data = {
					nombre: String(fd.get("nombre") ?? "").trim(),
					email: String(fd.get("email") ?? "").trim(),
					password: String(fd.get("password") ?? ""),
					passwordConfirm: String(fd.get("passwordConfirm") ?? ""),
				};

				if (!validate(data)) return;

				try {
					await api("/register", {
						method: "POST",
						body: JSON.stringify({
							nombre: data.nombre,
							email: data.email,
							password: data.password,
						}),
					});
					const loginRes = await api<{ token: string; rol: string; nombre: string }>("/login", {
						method: "POST",
						body: JSON.stringify({ email: data.email, password: data.password }),
					});
					auth.save(loginRes.token, loginRes.rol, loginRes.nombre);
					window.location.href = "/datos-fisicos";
				} catch (err: any) {
					if (err?.code === "CONFLICT") {
						setError("email", "Este email ya está registrado.");
					} else {
						setError("form", err?.error ?? "No se pudo completar el registro.");
					}
				}
			});

			const validate = (data: Record<string, string>) => {
				/*
				data: Objeto con atributos relacionados con el formulario que envia el usuario
				*/
				let ok = true;
				clearErrors(["nombre", "email", "password", "passwordConfirm", "form"]);

				if (data.nombre.length < 3 || data.nombre.length > 20) {
					setError("nombre", "El nombre debe tener entre 3 y 20 caracteres.");
					ok = false;
				}
				if (!EMAIL_REGEX.test(data.email)) {
					setError("email", "Introduce un email válido.");
					ok = false;
				}
				if (data.password.length < 8) {
					setError("password", "La contraseña debe tener al menos 8 caracteres.");
					ok = false;
				}
				if (data.password !== data.passwordConfirm) {
					setError("passwordConfirm", "Las contraseñas no coinciden.");
					ok = false;
				}
				return ok;
			};
		</script>
	</body>
</html>

<style>
	html, body {
		height: 100%;
		width: 100%;
		margin: 0;
	}
	body {
		min-height: 100%;
		background-image: url("/assets/landingBackGround2.png");
		background-position: center;
		background-size: cover;
		background-repeat: no-repeat;
		font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
	}
	main {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 6rem 1.5rem 3rem;
	}

	.card {
		width: 100%;
		max-width: 440px;
		padding: 2.5rem 2rem;
		background: rgba(255, 255, 255, 0.04);
		backdrop-filter: blur(16px) saturate(160%);
		-webkit-backdrop-filter: blur(16px) saturate(160%);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 20px;
		box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.35);
		color: #fff;
	}

	.cardHeader {
		text-align: center;
		margin-bottom: 1.75rem;
	}
	.cardHeader h1 {
		font-size: 2rem;
		font-weight: 800;
		margin: 0 0 0.5rem;
		background: linear-gradient(135.2deg, #52B788 0.6%, #2D6A4F 98.1%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.cardHeader p {
		color: rgba(255, 255, 255, 0.75);
		margin: 0;
		font-size: 0.95rem;
	}

	form {
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
	}
	.field {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	label {
		font-size: 0.85rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.85);
	}
	input {
		width: 100%;
		box-sizing: border-box;
		padding: 0.8rem 1rem;
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 12px;
		color: #fff;
		font-size: 1rem;
		transition: border-color 0.2s, background 0.2s;
	}
	input::placeholder {
		color: rgba(255, 255, 255, 0.4);
	}
	input:focus {
		outline: none;
		border-color: #52B788;
		background: rgba(255, 255, 255, 0.09);
	}
	input.invalid {
		border-color: #e05757;
	}

	.error {
		min-height: 1rem;
		font-size: 0.8rem;
		color: #ff8a8a;
	}
	.formError { text-align: center; }

	.submitButton {
		margin-top: 0.5rem;
		padding: 0.9rem 1.5rem;
		background: #2D6A4F;
		color: #fff;
		border: none;
		border-radius: 50px;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
		transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1),
			box-shadow 0.2s cubic-bezier(0.4, 0, 0.2, 1),
			background 0.2s;
		box-shadow: 0 4px 15px rgba(45, 106, 79, 0.3);
	}
	.submitButton:hover {
		background: #35805f;
		transform: translateY(-1px);
		box-shadow: 0 6px 20px rgba(45, 106, 79, 0.45);
	}
	.submitButton:active {
		transform: translateY(0);
	}

	.loginLink {
		text-align: center;
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.7);
		margin: 0.5rem 0 0;
	}
	.loginLink a {
		color: #52B788;
		text-decoration: none;
		font-weight: 600;
	}
	.loginLink a:hover {
		text-decoration: underline;
	}
</style>
</content>
</invoke>